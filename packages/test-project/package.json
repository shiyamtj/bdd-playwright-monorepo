{
  "name": "test-project",
  "version": "1.0.0",
  "description": "BDD test automation using @automite/bdd-playwright-framework",
  "private": true,
  "scripts": {
    "postinstall": "npx playwright install",
    "uninstall-browsers": "npx playwright uninstall",
    "clean": "rm -rf test-results && rm -rf reports",
    "clean:playwright-cache:windows": "rm -rf %USERPROFILE%\\AppData\\Local\\ms-playwright",
    "pretest": "npm run clean",
    "test": "cucumber-js",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:regression": "cucumber-js --tags @regression",
    "pretest:concurrent": "npm run clean",
    "test:concurrent": "ts-node run-tests.ts",
    "report": "node generate-report.js"
  },
  "keywords": [
    "cucumber",
    "playwright",
    "typescript",
    "bdd",
    "automation",
    "testing"
  ],
  "author": "shiyamtj@gmail.com",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@automite/bdd-playwright-framework": "*",
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.40.1"
  },
  "devDependencies": {
    "multiple-cucumber-html-reporter": "^3.10.0"
  }
}
