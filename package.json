{
  "name": "bdd-playwright-monorepo",
  "version": "1.0.0",
  "description": "BDD Playwright Framework Monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@automite/bdd-playwright-framework",
    "build:watch": "npm run dev --workspace=@automite/bdd-playwright-framework",
    "test": "npm run test --workspace=test-project",
    "test:smoke": "npm run test:smoke --workspace=test-project",
    "test:regression": "npm run test:regression --workspace=test-project",
    "test:concurrent": "npm run test:concurrent --workspace=test-project",
    "clean": "npm run clean --workspaces",
    "report": "npm run report --workspace=test-project",
    "install:all": "npm install"
  },
  "keywords": [
    "cucumber",
    "playwright",
    "typescript",
    "bdd",
    "automation",
    "testing",
    "monorepo"
  ],
  "author": "shiyamtj@gmail.com",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
